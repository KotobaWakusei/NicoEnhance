<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8F8F8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ====== 头部：图标 + 标题 ====== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="32dp"
            android:paddingBottom="24dp">

            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@mipmap/ic_launcher_foreground"
                android:contentDescription="NicoEnhance" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#DE000000"
                android:layout_marginTop="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="niconico增强模块"
                android:textSize="14sp"
                android:textColor="#99000000"
                android:layout_marginTop="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="功能开发中..."
                android:textSize="12sp"
                android:textColor="#66000000"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- ====== 状态卡片 ====== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFFFF"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="\u6A21\u5757\u72B6\u6001"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#DE000000" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="12dp">

                    <View
                        android:id="@+id/statusDot"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/circle_green" />

                    <TextView
                        android:id="@+id/statusText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  LSPosed \u6A21\u5757\u5DF2\u542F\u7528"
                        android:textSize="14sp"
                        android:textColor="#99000000" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="\u76EE\u6807\uFF1Ajp.nicovideo.android"
                    android:textSize="14sp"
                    android:textColor="#99000000"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ====== \u7EDF\u8BA1\u5361\u7247 ====== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFFFF"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="\u7FFB\u8BD1\u7EDF\u8BA1"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#DE000000" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/statTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2267"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="#FF2D55" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="\u603B\u5B57\u7B26\u4E32"
                            android:textSize="12sp"
                            android:textColor="#99000000"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/statTranslated"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="~800"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="#4CAF50" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="\u5DF2\u7FFB\u8BD1"
                            android:textSize="12sp"
                            android:textColor="#99000000"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/statRemaining"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="~1400"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="#FF9800" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="\u5F85\u7FFB\u8BD1"
                            android:textSize="12sp"
                            android:textColor="#99000000"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="\u26A0\uFE0F 翻译覆盖率约 35%，剩余字符串保持日文原文"
                    android:textSize="12sp"
                    android:textColor="#99000000"
                    android:layout_marginTop="12dp"
                    android:padding="8dp"
                    android:background="#1AFF9800" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ====== \u5173\u4E8E\u5361\u7247 ====== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="\u5173\u4E8E"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#DE000000" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nico增强模块通过 LSPosed 注入 niconico 动画，提供界面汉化等多种增强功能。"
                    android:textSize="14sp"
                    android:textColor="#99000000"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="4dp" />

                <TextView
                    android:id="@+id/versionInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="\u7248\u672C\uFF1A1.0"
                    android:textSize="12sp"
                    android:textColor="#66000000"
                    android:layout_marginTop="12dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 底部留白 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="32dp" />

    </LinearLayout>
</ScrollView>
